  iac: "AWS CDK (TypeScript)"
  cdk_language_note: >
    Same language as app and API — no context switching.
    Share types between CDK config and application config.

  stacks:
    SharedStack:
      description: "Deployed once — shared resources across all tenants"
      resources:
        - "VPC (2 AZs, private + public subnets)"
        - "ECS Cluster (Fargate)"
        - "Application Load Balancer (internet-facing, public)"
        - "Aurora Serverless v2 cluster + admin secret (Secrets Manager)"
        - "Schema setup Lambda (creates app.sessions, app.messages, app.session_files on first deploy)"
        - "ECR repository: chat-platform (single Nuxt image)"
        - "S3 bucket: tenant-files-{env} (shared across tenants — chat attachments)"
        - "  Lifecycle rule: expire objects after 90 days"
        - "  Versioning: disabled (no need for attachment versioning)"
        - "  Encryption: SSE-S3"
        - "CloudWatch log group: /platform/chat"
        - "Bedrock Guardrail (shared)"
        - "SSM Parameters: /chatplatform/db-url, /chatplatform/tenant-config"

    TenantStack:
      description: "Deployed per tenant — parameterised by tenantId"
      instantiation: |
        // cdk/bin/app.ts
        const tenants = ['acme', 'contoso', 'fabrikam']
        for (const tenantId of tenants) {
          new TenantStack(app, `TenantStack-${tenantId}`, {
            tenantId,
            shared: sharedStack,
            env: { account, region }
          })
        }
      resources:
        - "S3 bucket: {tenantId}-docs-{env}"
        - "Bedrock Knowledge Base: {tenantId}-kb-{env}"
        - "Bedrock Agent: {tenantId}-agent-{env}"
        - "Bedrock Agent Alias: {tenantId}-agent-alias-{env}"
        - "Aurora schema setup Lambda: creates vectors_{tenantId}.bedrock_kb"
        - "EventBridge Scheduler: daily KB sync (bedrockagent:startIngestionJob)"
        - "IAM role: BedrockAgentRole — access only to this tenant's KB"
        - "IAM role: KBIngestionRole — access only to this tenant's S3 bucket"
        - "CloudWatch log group: /platform/tenant/{tenantId}"

    UIStack:
      description: "One ECS service per tenant (same image, different env vars)"
      resources:
        - "ECS Service: chat-{tenantId} (Nuxt SSR, port 3000)"
        - "ALB listener rule: host-header {tenantId}.platform.example.com"
        - "Environment variables:"
        - "  NUXT_PUBLIC_TENANT_ID={tenantId}"
        - "  NUXT_PUBLIC_TENANT_NAME={displayName}"
        - "  TENANT_CONFIG={json from Secrets Manager}"
        - "  DATABASE_URL={from Secrets Manager}"
        - "  AWS_REGION=us-east-1"
        - "CloudWatch log group: /platform/chat-ui/{tenantId}"
      note: >
        No separate API ECS service. Nuxt server routes run inside this task.
        Single Docker image — ECR tag chat-platform:latest used by all tenants.

  cdk_project_structure: |
    cdk/
    ├── bin/
    │   └── app.ts              # Entry point — instantiates all stacks
    ├── lib/
    │   ├── shared-stack.ts     # VPC, ECS, ALB, Aurora, ECR, Guardrail
    │   ├── tenant-stack.ts     # S3, KB, Agent, Aurora schema, Scheduler
    │   ├── ui-stack.ts         # Per-tenant Nuxt ECS service
    │   └── constructs/
    │       ├── bedrock-kb.ts   # CfnKnowledgeBase + CfnDataSource
    │       ├── bedrock-agent.ts # CfnAgent + CfnAgentAlias
    │       └── aurora-schema.ts # Lambda custom resource for schema setup
    ├── config/
    │   └── tenants.ts          # Tenant definitions (tenantId, displayName, etc.)
    ├── cdk.json
    └── tsconfig.json


