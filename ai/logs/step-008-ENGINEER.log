+interface SaveObjectInput {
+  fileId: string
+  tenantId: string
+  userId: string
+  sessionId: string
+  fileName: string
+  contentType: string
+  bytes: Uint8Array
+}
+
+interface StoredObjectRecord {
+  bucket: string
+  key: string
+  sizeBytes: number
+}
+
+interface FileStorage {
+  saveFiles(inputs: SaveObjectInput[]): StoredObjectRecord[]
