+
+    for (const object of staged) {
+      this.objects.set(object.key, object.bytes)
+    }
+
+    return staged.map(({ bucket, key, sizeBytes }) => ({
+      bucket,
+      key,
+      sizeBytes,
+    }))
+  }
+}
